# Blueprint production crontab
# Install: crontab scripts/crontab.example

# Database backup daily at 2 AM
0 2 * * * /opt/blueprint/scripts/backup.sh >> /opt/blueprint/logs/backup.log 2>&1

# Monitor every 5 minutes
*/5 * * * * /opt/blueprint/scripts/monitor.sh >> /opt/blueprint/logs/monitor.log 2>&1

# SSL renewal check weekly
0 4 * * 0 certbot renew --quiet --deploy-hook "systemctl reload nginx" >> /opt/blueprint/logs/certbot.log 2>&1

# Log cleanup monthly (keep 30 days)
0 3 1 * * find /opt/blueprint/logs -name "*.log" -mtime +30 -delete
